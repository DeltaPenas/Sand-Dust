using System.Runtime.CompilerServices;
using UnityEngine; 
public class InimigoAtirador_CurtaDistancia : InimigoRanged // eu fiz ele atirando em cone para dar uma diferenciada
{
    [Header("Ataque")]
    public GameObject projetilPrefab;
    public Transform pontoDisparo;

    public int quantidadeTiros = 5;
    public float anguloTotal = 60f; // abertura do cone
    public float tempoEntreAtaques = 2f;

    private float tempoProximoAtaque;

    protected override void Comportamento()
    {
        float distancia = Vector2.Distance(transform.position, player.position);

        if (distancia <= distanciaParada && Time.time >= tempoProximoAtaque)
        {
            AtirarEmCone();
            tempoProximoAtaque = Time.time + tempoEntreAtaques;
        }
    }

    void AtirarEmCone()
    {
        Vector2 direcaoBase = (player.position - pontoDisparo.position).normalized; //mira no player

        float anguloInicial = -anguloTotal / 2f;
        float incremento = anguloTotal / (quantidadeTiros - 1); //angulo do do cone assim vai dar uns 60°

        for (int i = 0; i < quantidadeTiros; i++)
        {
            float angulo = anguloInicial + (incremento * i);

            Vector2 direcaoRotacionada = Quaternion.Euler(0, 0, angulo) * direcaoBase;

            GameObject proj = Instantiate(projetilPrefab, pontoDisparo.position, Quaternion.identity);

            proj.GetComponent<Rigidbody2D>().linearVelocity = direcaoRotacionada * 5f;
        } // isso diz quantos projeteis tem no cone eu coloquei 5 mas da para diminuir e aumentar traquilo assim com o angulo
    }
}